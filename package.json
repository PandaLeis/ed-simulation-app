{
  "name": "ed-simulation-app",
  "version": "0.1.0",
  "productName": "ED Provider Simulation",
  "description": "Synthetic ED provider flow training simulation.",
  "author": "PandaLeis",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "desktop": "npm run build && electron .",
    "desktop:pack": "npm run build && electron-builder --dir",
    "desktop:dist:win": "npm run build && electron-builder --win nsis",
    "dev": "vite",
    "preview": "vite preview",
    "demo": "tsx src/simulation/smokeDemo.ts",
    "test": "tsx --test src/simulation/__tests__/*.test.ts"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^1.18.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vite": "^8.0.16"
  },
  "build": {
    "appId": "com.pandaleis.ed-simulation-app",
    "productName": "ED Provider Simulation",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ED-Provider-Simulation-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
